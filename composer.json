{
    "name": "michaelalexeevweb/php-json-chunk",
    "description": "Read JSON arrays from files and return chunked data.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "json",
        "chunk",
        "parser"
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "PhpJsonChunk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpJsonChunk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:performance": "RUN_PERFORMANCE_TESTS=1 phpunit --group performance"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

